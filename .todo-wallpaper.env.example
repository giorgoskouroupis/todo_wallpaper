MODE=opencode
TODO_FILE=$HOME/.local/share/todo_wallpaper/TODO.md
OUTPUT_FILE=$HOME/Pictures/Wallpapers/TODO/todo-wallpaper.png
BACKEND=auto
SCREEN=all
BOX_POSITION=right
DISPLAY_ORDER_PRIORITIES=true
FONT_NAME=
WIDTH=
HEIGHT=
SCALE=3.0
APPLY_WALLPAPER=1
ENABLE_WATCHER=0
INSTALL_DIR=$HOME/.local/share/todo_wallpaper
CONFIG_DIR=$HOME/.config/todo_wallpaper
UNIT_DIR=$HOME/.config/systemd/user
