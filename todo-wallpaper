#!/bin/sh

set -eu

SELF_PATH="$0"
while [ -L "$SELF_PATH" ]; do
  LINK_TARGET=$(readlink "$SELF_PATH")
  case "$LINK_TARGET" in
    /*)
      SELF_PATH="$LINK_TARGET"
      ;;
    *)
      SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$SELF_PATH")" && pwd)
      SELF_PATH="$SELF_DIR/$LINK_TARGET"
      ;;
  esac
done

PROJECT_DIR=$(CDPATH= cd -- "$(dirname -- "$SELF_PATH")" && pwd)
OPENCODE_BIN="${OPENCODE_BIN:-opencode}"
AUTO_APPROVE=0

. "$PROJECT_DIR/scripts/common.sh"

usage() {
  printf 'usage: %s [--yes] <command> [args]\n' "$0"
  printf '\n'
  printf '%s\n' 'view:'
  printf '  %s status\n' "$0"
  printf '  %s config\n' "$0"
  printf '  %s doctor\n' "$0"
  printf '  %s list\n' "$0"
  printf '\n'
  printf '%s\n' 'wallpaper:'
  printf '  %s refresh\n' "$0"
  printf '  %s show\n' "$0"
  printf '  %s hide\n' "$0"
  printf '\n'
  printf '%s\n' 'edit:'
  printf '  %s edit\n' "$0"
  printf '  %s add [-n LINE] [-H|--high|-M|--medium|-N|--normal] <task text>\n' "$0"
  printf '  %s replace -n LINE [-H|--high|-M|--medium|-N|--normal] <task text>\n' "$0"
  printf '  %s change-priority -n LINE (-H|--high|-M|--medium|-N|--normal|high|medium|normal)\n' "$0"
  printf '  %s done -n LINE [-n LINE ...]\n' "$0"
  printf '  %s undone -n LINE [-n LINE ...]\n' "$0"
  printf '  %s remove -n LINE [-n LINE ...]\n' "$0"
  printf '\n'
  printf '%s\n' 'watcher and cleanup:'
  printf '  %s watch-on\n' "$0"
  printf '  %s watch-off\n' "$0"
  printf '  %s uninstall\n' "$0"
}

resolve_opencode_bin() {
  if command -v "$OPENCODE_BIN" >/dev/null 2>&1; then
    command -v "$OPENCODE_BIN"
    return
  fi
  if [ -x "$HOME/.opencode/bin/opencode" ]; then
    printf '%s\n' "$HOME/.opencode/bin/opencode"
    return
  fi
  printf '\n'
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes)
      AUTO_APPROVE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

COMMAND="${1:-}"
if [ -z "$COMMAND" ]; then
  usage >&2
  exit 2
fi

ensure_default_config
if [ -f "$DEFAULT_CONFIG_FILE" ]; then
  # shellcheck disable=SC1091
  . "$DEFAULT_CONFIG_FILE"
fi

MODE="${MODE:-self-contained}"

case "$COMMAND" in
  refresh|show|hide|status|config|doctor|watch-on|watch-off|list|edit|add|replace|change-priority|done|undone|remove|uninstall)
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

if [ "$MODE" = "opencode" ] && [ "$COMMAND" != "uninstall" ]; then
  printf 'OpenCode-managed mode is bootstrap plus handoff.\n' >&2
  printf 'Start OpenCode in: %s\n' "$PROJECT_DIR" >&2
  printf 'Paste the handoff prompt shown by install.sh, or read OPENCODE_HANDOFF.md in this directory.\n' >&2
  exit 1
fi

shift
exec "$PROJECT_DIR/scripts/manage_mode.sh" "$COMMAND" "$DEFAULT_CONFIG_FILE" "$@"
